# ===========================================
# Lavadero — variables de entorno (ejemplo)
# Copiar a .env y completar valores reales.
# Nunca commitear .env con secretos.
# ===========================================

# --- Base de datos (PostgreSQL) ---
# Local típico: puerto 5432. Si tu instancia escucha en otro puerto (ej. 5433), ajustá el número.
# Para desarrollo limpio se recomienda una base dedicada (ej. lavadero_dev), no reutilizar una BD vieja con esquema distinto.
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@localhost:5433/lavadero_dev?schema=public"

# --- NextAuth (obligatorio en cualquier entorno) ---
# Generar: openssl rand -base64 32
NEXTAUTH_SECRET="reemplazar-con-secreto-largo-aleatorio"
# Debe coincidir con la URL y puerto con los que abrís la app en el navegador.
NEXTAUTH_URL="http://localhost:3000"

# --- App ---
APP_NAME="Lavadero Sistema"
APP_URL="http://localhost:3000"
# Opcional: fijar puerto de Next
#PORT=3000
NODE_ENV="development"

# --- Seed local (npm run db:seed) — NO usar en producción ---
# El seed aborta si NODE_ENV=production.
# Si defines SEED_* aquí, el login usa exactamente ese texto.
# Si NO defines SEED_*, el seed usa por defecto: admin123, encargado123, lavador123.
#SEED_ADMIN_PASSWORD="tu-clave-local"
#SEED_ENCARGADO_PASSWORD="tu-clave-local"
#SEED_LAVADOR_PASSWORD="tu-clave-local"
SEED_TEST_USER="admin"