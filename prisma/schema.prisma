// Schema de Base de Datos - Sistema Lavadero de Autos
// Generado basado en src/types/index.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // PostgreSQL (cambiar a "sqlite" solo si se convierte enums a String)
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  DUENO
  ENCARGADO
  LAVADOR
  CLIENTE
}

enum OTEstado {
  EN_COLA
  EN_PROCESO
  LISTO
  ENTREGADO
  CANCELADO
}

enum TipoVehiculo {
  chico
  mediano
  camioneta
}

enum MedioPago {
  EFECTIVO
  TRANSFERENCIA
}

enum ComisionEstado {
  PENDIENTE
  LIQUIDADA
}

enum ComisionModelo {
  POR_ITEM
  POR_OT
}

enum TipoCliente {
  CONCESIONARIA
  WALK_IN
}

// Tipo de movimiento de stock de insumos.
enum TipoMovimientoStock {
  ENTRADA    // compra / reposición (suma)
  SALIDA     // consumo manual (resta)
  AJUSTE     // corrección por inventario físico (± )
  CONSUMO    // consumo automático por receta al completar una OT (resta)
  DEVOLUCION // reverso automático al cancelar una OT ya consumida (suma)
}

// ============================================
// MODELOS
// ============================================

// Empresa (tenant de la plataforma): cada lavadero-cliente es una Empresa.
// El ADMIN de plataforma (empresaId null en Usuario) las administra todas.
model Empresa {
  id        String   @id @default(cuid())
  nombre    String   @unique
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sucursales     Sucursal[]
  usuarios       Usuario[]
  clientes       Cliente[]
  servicios      Servicio[]
  extras         Extra[]
  ordenesTrabajo OrdenTrabajo[]
  cierres        CierreCaja[]
  productosStock ProductoStock[]
  movimientosStock MovimientoStock[]
  recetasInsumo  RecetaInsumo[]

  @@map("empresas")
}

// Sucursal del lavadero. Los negocios de una sola sede tienen la "Principal"
// (creada por la migración/seed) y la UI oculta el selector.
model Sucursal {
  id        String   @id @default(cuid())
  empresaId String
  nombre    String
  direccion String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa        Empresa        @relation(fields: [empresaId], references: [id])
  usuarios       Usuario[]
  ordenesTrabajo OrdenTrabajo[]
  cierres        CierreCaja[]
  servicios      Servicio[]
  extras         Extra[]
  productosStock ProductoStock[]
  movimientosStock MovimientoStock[]
  recetasInsumo  RecetaInsumo[]

  @@unique([empresaId, nombre])
  @@index([empresaId])
  @@map("sucursales")
}

model Usuario {
  id         String   @id @default(cuid())
  nombre     String
  usuario    String   @unique // login username (único en toda la plataforma)
  password   String   // hash de contraseña
  rol        UserRole
  empresaId  String?  // Empresa a la que pertenece; null SOLO para ADMIN de plataforma
  clienteId  String?  // Si rol=CLIENTE, referencia a concesionaria (Cliente)
  sucursalId String?  // ENCARGADO/LAVADOR pertenecen a una sucursal; DUENO null = todas las de su empresa
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relaciones
  empresa             Empresa?            @relation(fields: [empresaId], references: [id])
  cliente             Cliente?            @relation(fields: [clienteId], references: [id])
  sucursal            Sucursal?           @relation(fields: [sucursalId], references: [id])
  otsCreadas          OrdenTrabajo[]       @relation("OTCreador")
  otsAsignadas        OrdenTrabajoEmpleado[]
  pagosRegistrados    Pago[]
  cierresRealizados   CierreCaja[]
  comisiones          Comision[]
  comisionesLiquidadas LiquidacionComision[] @relation("LiquidacionEmpleado")
  liquidacionesRealizadas  LiquidacionComision[] @relation("LiquidacionUsuario")
  configComisiones    ConfigComision[]
  estadosCambiados    EstadoHistorial[]
  auditoriaLogs       AuditoriaLog[]
  movimientosStock    MovimientoStock[]

  @@index([clienteId])
  @@index([sucursalId])
  @@index([empresaId])
  @@map("usuarios")
}

model Servicio {
  id              String        @id @default(cuid())
  empresaId       String
  nombre          String
  precio          Decimal       @db.Decimal(12, 2)
  duracionEstimada Int?         // en minutos
  tipoVehiculo    TipoVehiculo?
  sucursalId      String?       // null = compartido entre todas las sucursales de la empresa
  activo          Boolean       @default(true)
  descripcion     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relaciones
  empresa         Empresa       @relation(fields: [empresaId], references: [id])
  sucursal        Sucursal?     @relation(fields: [sucursalId], references: [id])
  ots             OrdenTrabajo[]
  recetas         RecetaInsumo[]

  // El nombre es único dentro de cada sucursal (y una vez como "compartido",
  // sucursalId null). Permite el mismo servicio con precio propio por sede.
  @@unique([empresaId, sucursalId, nombre])
  @@index([empresaId])
  @@index([sucursalId])
  @@map("servicios")
}

model Extra {
  id              String        @id @default(cuid())
  empresaId       String
  nombre          String
  precio          Decimal       @db.Decimal(12, 2)
  duracionEstimada Int?         // en minutos
  sucursalId      String?       // null = compartido entre todas las sucursales de la empresa
  activo          Boolean       @default(true)
  descripcion     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relaciones
  empresa         Empresa       @relation(fields: [empresaId], references: [id])
  sucursal        Sucursal?     @relation(fields: [sucursalId], references: [id])
  ots             OrdenTrabajoExtra[]
  recetas         RecetaInsumo[]

  // Mismo criterio que Servicio: único por sucursal (o una vez compartido).
  @@unique([empresaId, sucursalId, nombre])
  @@index([empresaId])
  @@index([sucursalId])
  @@map("extras")
}

model Cliente {
  id                  String      @id @default(cuid())
  empresaId           String
  nombre              String
  tipo                TipoCliente @default(WALK_IN)
  telefono            String?
  email               String?
  descuentoPorcentaje Float?      // Porcentaje de descuento (ej: 10 para 10% off)
  trabajoExterno      Boolean     @default(false) // Si true, OT sin turnos (se trabaja fuera del lavadero)
  usaMontosFijos      Boolean     @default(false) // Si true, usa montos fijos por servicio/extra en vez de descuento
  montosFijosServicios Json?      // { [servicioId]: number }
  montosFijosExtras    Json?      // { [extraId]: number }
  prioridad           Int         @default(0) // Mayor número = mayor prioridad
  activo              Boolean     @default(true)
  observaciones       String?     // Notas sobre el cliente
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relaciones
  empresa             Empresa     @relation(fields: [empresaId], references: [id])
  ordenesTrabajo      OrdenTrabajo[]
  portalUsuarios      Usuario[]

  @@unique([empresaId, nombre])
  @@index([empresaId])
  @@index([tipo])
  @@index([activo])
  @@index([prioridad])
  @@map("clientes")
}

model OrdenTrabajo {
  id                  String      @id @default(cuid())
  fechaIngreso        DateTime    @default(now())
  patente             String      // Obligatorio ahora
  tipoVehiculo        TipoVehiculo? // Opcional ahora
  descripcionVehiculo String?
  fotoUrl             String?     // Foto del vehículo al ingresar (ruta/URL)
  nombreCliente       String?     // Nuevo: nombre del cliente (temporalmente opcional para migración)
  telefonoCliente     String?     // Nuevo: teléfono del cliente (temporalmente opcional para migración)
  horarioDeseado      DateTime?   // Nuevo: horario en que quiere tenerlo listo
  esExterna           Boolean     @default(false) // OT fuera del lavadero: no ocupa turnos ni genera conflictos
  clienteId           String?     // Cliente fijo (concesionaria), null para walk-in
  empresaId           String      // Empresa dueña de la OT (scoping multi-tenant)
  sucursalId          String      // Sucursal donde se realiza la OT
  servicioId          String
  observaciones       String?
  estado              OTEstado    @default(EN_COLA)
  total               Decimal     @db.Decimal(12, 2)
  precioAjustado      Decimal?    @db.Decimal(12, 2) // si se ajusta manualmente
  justificacionPrecio String?
  usuarioCreadorId    String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relaciones
  cliente             Cliente?            @relation(fields: [clienteId], references: [id])
  empresa             Empresa             @relation(fields: [empresaId], references: [id])
  sucursal            Sucursal            @relation(fields: [sucursalId], references: [id])
  servicio            Servicio            @relation(fields: [servicioId], references: [id])
  usuarioCreador      Usuario             @relation("OTCreador", fields: [usuarioCreadorId], references: [id])
  empleados           OrdenTrabajoEmpleado[]
  extras              OrdenTrabajoExtra[]
  estadosHistorial    EstadoHistorial[]
  pagos               Pago[]
  comisiones          Comision[]
  cierres             CierreCajaOT[]
  movimientosStock    MovimientoStock[]

  @@index([estado])
  @@index([fechaIngreso])
  @@index([usuarioCreadorId])
  @@index([clienteId])
  @@index([sucursalId])
  @@index([empresaId])
  @@map("ordenes_trabajo")
}

// Tabla de relación muchos a muchos: OT - Empleados
model OrdenTrabajoEmpleado {
  id            String        @id @default(cuid())
  ordenTrabajoId String
  empleadoId    String

  ordenTrabajo  OrdenTrabajo  @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  empleado      Usuario       @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@unique([ordenTrabajoId, empleadoId])
  @@map("orden_trabajo_empleados")
}

// Tabla de relación muchos a muchos: OT - Extras
model OrdenTrabajoExtra {
  id            String        @id @default(cuid())
  ordenTrabajoId String
  extraId       String

  ordenTrabajo  OrdenTrabajo  @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  extra         Extra         @relation(fields: [extraId], references: [id], onDelete: Cascade)

  @@unique([ordenTrabajoId, extraId])
  @@map("orden_trabajo_extras")
}

model EstadoHistorial {
  id            String      @id @default(cuid())
  ordenTrabajoId String
  estadoAnterior OTEstado
  estadoNuevo    OTEstado
  usuarioId     String
  fechaHora     DateTime    @default(now())

  // Relaciones
  ordenTrabajo  OrdenTrabajo @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  usuario       Usuario      @relation(fields: [usuarioId], references: [id])

  @@index([ordenTrabajoId])
  @@index([fechaHora])
  @@map("estado_historial")
}

model Pago {
  id            String      @id @default(cuid())
  ordenTrabajoId String
  monto         Decimal     @db.Decimal(12, 2)
  medioPago     MedioPago
  referencia    String?     // para transferencias (CBU, alias, número de operación)
  fechaHora     DateTime    @default(now())
  usuarioId     String
  createdAt     DateTime    @default(now())

  // Relaciones
  ordenTrabajo  OrdenTrabajo @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  usuario       Usuario      @relation(fields: [usuarioId], references: [id])

  @@index([ordenTrabajoId])
  @@index([fechaHora])
  @@index([medioPago])
  @@map("pagos")
}

model CierreCaja {
  id                String      @id @default(cuid())
  empresaId         String      // Empresa dueña del cierre (scoping multi-tenant)
  fechaDesde        DateTime
  fechaHasta        DateTime
  fechaCierre       DateTime    @default(now())
  totalEfectivo     Decimal     @db.Decimal(12, 2)
  totalTransferencia Decimal    @db.Decimal(12, 2)
  totalGeneral      Decimal     @db.Decimal(12, 2)
  observaciones     String?
  sucursalId        String      // El cierre de caja es por sucursal
  usuarioId         String
  createdAt         DateTime    @default(now())

  // Relaciones
  empresa           Empresa     @relation(fields: [empresaId], references: [id])
  sucursal          Sucursal    @relation(fields: [sucursalId], references: [id])
  usuario           Usuario     @relation(fields: [usuarioId], references: [id])
  ots               CierreCajaOT[]

  @@index([fechaCierre])
  @@index([usuarioId])
  @@index([sucursalId])
  @@index([empresaId])
  @@map("cierres_caja")
}

// Tabla de relación muchos a muchos: Cierre de Caja - OTs
model CierreCajaOT {
  id            String      @id @default(cuid())
  cierreCajaId  String
  ordenTrabajoId String

  cierreCaja    CierreCaja  @relation(fields: [cierreCajaId], references: [id], onDelete: Cascade)
  ordenTrabajo  OrdenTrabajo @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)

  @@unique([cierreCajaId, ordenTrabajoId])
  @@map("cierre_caja_ots")
}

model Comision {
  id                    String          @id @default(cuid())
  ordenTrabajoId        String
  empleadoId            String
  monto                 Decimal         @db.Decimal(12, 2)
  porcentaje            Float // porcentaje aplicado
  estado                ComisionEstado  @default(PENDIENTE)
  fechaGeneracion       DateTime        @default(now())
  fechaLiquidacion      DateTime?
  usuarioLiquidacionId  String?
  createdAt             DateTime        @default(now())

  // Relaciones
  ordenTrabajo          OrdenTrabajo    @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  empleado              Usuario         @relation(fields: [empleadoId], references: [id])
  liquidaciones         LiquidacionComisionComision[]

  @@index([empleadoId])
  @@index([estado])
  @@index([fechaGeneracion])
  @@map("comisiones")
}

model ConfigComision {
  id                    String          @id @default(cuid())
  empleadoId            String          @unique
  modelo                ComisionModelo  @default(POR_ITEM)
  porcentaje            Float // porcentaje base
  porcentajePorServicio String?           // { servicioId: porcentaje } - para modelo POR_ITEM
  activo                Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  // Relaciones
  empleado              Usuario         @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@map("config_comisiones")
}

model LiquidacionComision {
  id            String      @id @default(cuid())
  empleadoId    String
  fechaDesde    DateTime
  fechaHasta    DateTime
  fechaLiquidacion DateTime @default(now())
  montoTotal    Decimal     @db.Decimal(12, 2)
  usuarioId     String
  createdAt     DateTime    @default(now())

  // Relaciones
  empleado      Usuario     @relation("LiquidacionEmpleado", fields: [empleadoId], references: [id])
  usuario       Usuario     @relation("LiquidacionUsuario", fields: [usuarioId], references: [id])
  comisiones    LiquidacionComisionComision[]

  @@index([empleadoId])
  @@index([fechaLiquidacion])
  @@map("liquidaciones_comision")
}

// Tabla de relación muchos a muchos: Liquidación - Comisiones
model LiquidacionComisionComision {
  id                  String              @id @default(cuid())
  liquidacionId       String
  comisionId          String

  liquidacion         LiquidacionComision @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  comision            Comision            @relation(fields: [comisionId], references: [id], onDelete: Cascade)

  @@unique([liquidacionId, comisionId])
  @@map("liquidacion_comision_comisiones")
}

model AuditoriaLog {
  id            String   @id @default(cuid())
  fechaHora     DateTime @default(now())
  usuarioId     String
  accion        String   // ejemplo: "OT_CREATED", "OT_STATE_CHANGED", "PAYMENT_REGISTERED"
  entidad       String   // ejemplo: "OrdenTrabajo", "Pago", "CierreCaja"
  entidadId     String?  // ID de la entidad afectada
  datos         String     // datos adicionales en formato JSON

  // Relaciones
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([fechaHora])
  @@index([usuarioId])
  @@index([entidad, entidadId])
  @@map("auditoria_logs")
}

// ============================================
// STOCK DE INSUMOS (Etapa 1: control manual)
// ============================================

// Producto/insumo del depósito (cera, shampoo, esponjas, etc.).
// El stock es POR SUCURSAL: cada sede tiene su propio depósito y saldo.
// stockActual es un saldo materializado que se actualiza en la MISMA
// transacción que cada movimiento (el ledger inmutable es MovimientoStock).
model ProductoStock {
  id           String   @id @default(cuid())
  empresaId    String
  sucursalId   String
  nombre       String
  unidad       String   @default("unidad") // "L", "ml", "kg", "g", "unidad"
  stockActual  Decimal  @default(0) @db.Decimal(12, 3)
  stockMinimo  Decimal  @default(0) @db.Decimal(12, 3) // umbral de alerta de reposición
  costoUnitario Decimal? @db.Decimal(12, 2) // último costo de compra conocido (por unidad)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  empresa      Empresa            @relation(fields: [empresaId], references: [id])
  sucursal     Sucursal           @relation(fields: [sucursalId], references: [id])
  movimientos  MovimientoStock[]
  recetas      RecetaInsumo[]

  @@unique([sucursalId, nombre])
  @@index([empresaId])
  @@index([sucursalId])
  @@map("productos_stock")
}

// Movimiento de stock (ledger inmutable). El saldo de un producto es la
// suma de los `cantidad` (con signo) de sus movimientos.
model MovimientoStock {
  id            String              @id @default(cuid())
  empresaId     String
  sucursalId    String
  productoId    String
  tipo          TipoMovimientoStock
  cantidad      Decimal             @db.Decimal(12, 3) // delta con signo aplicado al stock (ENTRADA/DEVOLUCION +, SALIDA/CONSUMO -, AJUSTE ±)
  costoUnitario Decimal?            @db.Decimal(12, 2) // costo por unidad (ENTRADA; y CONSUMO guarda el costo al que se consumió)
  motivo        String?
  ordenTrabajoId String?            // OT que originó el movimiento (CONSUMO/DEVOLUCION automáticos)
  usuarioId     String
  fechaHora     DateTime            @default(now())
  createdAt     DateTime            @default(now())

  empresa       Empresa        @relation(fields: [empresaId], references: [id])
  sucursal      Sucursal       @relation(fields: [sucursalId], references: [id])
  producto      ProductoStock  @relation(fields: [productoId], references: [id])
  ordenTrabajo  OrdenTrabajo?  @relation(fields: [ordenTrabajoId], references: [id])
  usuario       Usuario        @relation(fields: [usuarioId], references: [id])

  @@index([empresaId])
  @@index([sucursalId])
  @@index([productoId])
  @@index([ordenTrabajoId])
  @@index([fechaHora])
  @@map("movimientos_stock")
}

// Receta (Etapa 2): qué insumo y cuánto consume un servicio o un extra.
// Es POR SUCURSAL porque apunta a un ProductoStock (que es de una sucursal).
// Cada línea liga UN servicio O UN extra (uno de los dos) con un producto.
model RecetaInsumo {
  id              String   @id @default(cuid())
  empresaId       String
  sucursalId      String
  servicioId      String?  // exactamente uno de servicioId / extraId
  extraId         String?
  productoStockId String
  cantidad        Decimal  @db.Decimal(12, 3) // cantidad consumida por cada OT de ese servicio/extra
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  empresa         Empresa        @relation(fields: [empresaId], references: [id])
  sucursal        Sucursal       @relation(fields: [sucursalId], references: [id])
  servicio        Servicio?      @relation(fields: [servicioId], references: [id])
  extra           Extra?         @relation(fields: [extraId], references: [id])
  producto        ProductoStock  @relation(fields: [productoStockId], references: [id])

  // Una línea por (servicio, producto) y por (extra, producto). Postgres trata
  // los NULL como distintos, así que no chocan las filas de servicio vs extra.
  @@unique([servicioId, productoStockId])
  @@unique([extraId, productoStockId])
  @@index([empresaId])
  @@index([sucursalId])
  @@index([servicioId])
  @@index([extraId])
  @@index([productoStockId])
  @@map("recetas_insumo")
}

